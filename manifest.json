    {
      "name": "ua_find_callers",
      "description": "Find all callers of a specific function or file up to a certain depth. Helps trace execution paths.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "description": "Required. The file path, function name, or module. Example: 'src/core/db.ts' or 'calculateStats'."
          },
          "depth": {
            "type": "number",
            "description": "Optional. The maximum depth to trace callers. Defaults to 3. Maximum is 10."
          }
        },
        "required": [
          "target"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
